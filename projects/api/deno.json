{
  "name": "@trakt/api",
  "exports": "./mod.ts",
  "version": "0.5.0",
  "imports": {
    "@anatine/zod-openapi": "npm:@anatine/zod-openapi@^2.2.6",
    "@std/testing": "jsr:@std/testing@^1.0.5",
    "@ts-rest/core": "npm:@ts-rest/core@^3.52.1",
    "zod": "npm:zod@^3.24.1"
  },
  "lint": {
    "exclude": [
      "scripts",
      "types"
    ]
  },
  "publish": {
    "include": [
      "mod.ts",
      "deno.json",
      "src",
      "types"
    ],
    "exclude": [
      "**/*.test.ts"
    ]
  },
  "tasks": {
    "test": "deno test --unstable --allow-all",
    "build:types": "deno run -A --no-lock scripts/build-types.ts",
    "publish": "deno task build:types && deno publish",
    "publish:check": "deno task build:types && deno publish --dry-run --allow-dirty"
  }
}
